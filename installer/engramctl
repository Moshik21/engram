compose() {
  detect_docker_compose
  "${DOCKER_COMPOSE[@]}" --env-file "$FULL_ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

wait_for_health() {
  local port="${ENGRAM_API_PORT:-8100}"
  local attempts=60
  local url="http://127.0.0.1:${port}/health"

  while [ "$attempts" -gt 0 ]; do
    if curl --connect-timeout 1 --max-time 5 -fsS "$url" >/dev/null 2>&1; then
      return 0
    fi
    attempts=$((attempts - 1))
    sleep 2
  done
  die "Engram did not become healthy at $url in time."
}

open_dashboard() {
  [ "${ENGRAM_INSTALL_SKIP_OPEN:-0}" = "1" ] && return 0
  local port="${ENGRAM_DASHBOARD_PORT:-3000}"
  local url="http://127.0.0.1:${port}"
  if command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1 || true
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 || true
  fi
}

verify_api_reachable() {
  local port="${ENGRAM_API_PORT:-8100}"
  curl --connect-timeout 1 --max-time 5 -fsS "http://127.0.0.1:${port}/health" >/dev/null 2>&1 \
    || die "Engram API is not reachable on 127.0.0.1:${port}."
}

api_base_url() {
  local port="${ENGRAM_API_PORT:-8100}"
  echo "http://127.0.0.1:${port}"
}

load_local_env() {
  [ -f "$LITE_ENV_FILE" ] || die "No local install found. Run engramctl quickstart first."
  load_existing_env "$LITE_ENV_FILE"
}

write_mcp_http_config() {
  local target="$1"
  local url="$2"
  mkdir -p "$(dirname "$target")"
  python3 - "$target" "$url" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
url = sys.argv[2]
data = {}
if path.exists():
    try:
        data = json.loads(path.read_text())
    except json.JSONDecodeError:
        backup = path.with_suffix(path.suffix + ".bak")
        backup.write_text(path.read_text())
        data = {}
data.setdefault("mcpServers", {})["engram"] = {"type": "http", "url": url}
path.write_text(json.dumps(data, indent=2) + "\n")
PY
}

write_codex_mcp_config() {
  local target="$1"
  local url="$2"
  mkdir -p "$(dirname "$target")"
  python3 - "$target" "$url" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
url = sys.argv[2]
text = path.read_text() if path.exists() else ""

if text and not text.endswith("\n"):
    text += "\n"

text = re.sub(r"(?ms)^\[mcp_servers\.engram\]\n.*?(?=^\[|\Z)", "", text)

mcp_match = re.search(r"(?ms)^(\[mcp\]\n)(.*?)(?=^\[|\Z)", text)
if mcp_match:
    body = mcp_match.group(2)
    if re.search(r"(?m)^remote_mcp_client_enabled\s*=", body):
        body = re.sub(
            r"(?m)^remote_mcp_client_enabled\s*=.*$",
            "remote_mcp_client_enabled = true",
            body,
        )
    else:
        body = "remote_mcp_client_enabled = true\n" + body
    text = text[: mcp_match.start()] + mcp_match.group(1) + body + text[mcp_match.end() :]
else:
    text = "[mcp]\nremote_mcp_client_enabled = true\n\n" + text.lstrip("\n")

text = text.rstrip() + "\n\n[mcp_servers.engram]\n"
text += f"url = {json.dumps(url)}\n"
path.write_text(text)
PY
}

