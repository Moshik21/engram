diff --git a/helix-db/proto/helix.proto b/helix-db/proto/helix.proto
new file mode 100644
index 0000000..85dda85
--- /dev/null
+++ b/helix-db/proto/helix.proto
@@ -0,0 +1,35 @@
+syntax = "proto3";
+package helix.v1;
+
+service HelixDB {
+  rpc Query(QueryRequest) returns (QueryResponse);
+  rpc Batch(BatchRequest) returns (BatchResponse);
+  rpc StreamQuery(stream QueryRequest) returns (stream QueryResponse);
+}
+
+message QueryRequest {
+  string name = 1;
+  bytes body = 2;
+  string api_key = 3;
+  RequestType req_type = 4;
+}
+
+enum RequestType {
+  QUERY = 0;
+  MCP = 1;
+}
+
+message QueryResponse {
+  int32 status = 1;
+  bytes body = 2;
+  string error = 3;
+  string error_code = 4;
+}
+
+message BatchRequest {
+  repeated QueryRequest queries = 1;
+}
+
+message BatchResponse {
+  repeated QueryResponse results = 1;
+}
