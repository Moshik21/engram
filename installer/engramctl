#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

info() { echo -e "  ${GREEN}*${RESET} $1"; }
warn() { echo -e "  ${RED}!${RESET} $1"; }
note() { echo -e "  ${CYAN}>${RESET} $1"; }
dim() { echo -e "  ${DIM}$1${RESET}"; }
die() { warn "$1"; exit 1; }

resolve_self() {
  local source="${BASH_SOURCE[0]}"
  while [ -h "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

SCRIPT_DIR="$(resolve_self)"
BUNDLE_ROOT="$SCRIPT_DIR"
ENGRAM_HOME="${ENGRAM_HOME:-$HOME/.engram}"
INSTALL_ROOT="${ENGRAM_INSTALL_ROOT:-$ENGRAM_HOME/full}"
BIN_DIR="${ENGRAM_INSTALL_BIN_DIR:-$HOME/.local/bin}"
COMPOSE_FILE="$INSTALL_ROOT/current/compose.yaml"
METADATA_FILE="$BUNDLE_ROOT/release-metadata.env"
DEFAULT_RELEASE_REPOSITORY="${ENGRAM_RELEASE_REPOSITORY:-Moshik21/engram}"
OPENCLAW_SKILL_SLUG="${ENGRAM_OPENCLAW_SKILL_SLUG:-engram-brain}"
HELIX_NATIVE_VERSION="${ENGRAM_HELIX_NATIVE_VERSION:-0.1.0}"
HELIX_NATIVE_SUBDIR="native/helix-repo/helix-python"

# Lite mode paths
LITE_ENV_FILE="$ENGRAM_HOME/.env"
LITE_PID_FILE="$ENGRAM_HOME/engram.pid"
LITE_LOG_DIR="$ENGRAM_HOME/logs"
LITE_LOG_FILE="$LITE_LOG_DIR/engram.log"
LITE_DB_FILE="$ENGRAM_HOME/engram.db"
LITE_LAUNCH_AGENT_LABEL="${ENGRAM_LAUNCH_AGENT_LABEL:-dev.engram.local}"
LITE_LAUNCH_AGENT_PLIST="${ENGRAM_LAUNCH_AGENT_PLIST:-$HOME/Library/LaunchAgents/${LITE_LAUNCH_AGENT_LABEL}.plist}"

# Full mode paths
FULL_ENV_FILE="$INSTALL_ROOT/.env"

if [ -f "$METADATA_FILE" ]; then
  # shellcheck disable=SC1090
  source "$METADATA_FILE"
fi

DOCKER_COMPOSE=()

discover_helix_native_release_wheel() {
  [ "${ENGRAM_HELIX_NATIVE_SKIP_RELEASE_WHEEL:-0}" = "1" ] && return 1
  command -v python3 >/dev/null 2>&1 || return 1

  local metadata_file api_url
  metadata_file="$(mktemp)"
  api_url="https://api.github.com/repos/${DEFAULT_RELEASE_REPOSITORY}/releases/latest"
  if ! curl -fsSL "$api_url" -o "$metadata_file" 2>/dev/null; then
    rm -f "$metadata_file"
    return 1
  fi

  local wheel_url
  wheel_url="$(
    python3 - "$metadata_file" "$HELIX_NATIVE_VERSION" <<'PY'
import json
import platform
import sys

metadata_path, expected_version = sys.argv[1], sys.argv[2]
try:
    assets = json.load(open(metadata_path, encoding="utf-8")).get("assets", [])
except Exception:
    sys.exit(1)

system = platform.system()
machine = platform.machine().lower()
py_tag = f"cp{sys.version_info.major}{sys.version_info.minor}"

if machine in {"arm64", "aarch64"}:
    arch = "arm64" if system == "Darwin" else "aarch64"
elif machine in {"x86_64", "amd64"}:
    arch = "x86_64"
else:
    sys.exit(1)

def score(asset):
    name = asset.get("name", "").lower()
    if not name.endswith(".whl") or not name.startswith("helix_native-"):
        return -1
    if expected_version and f"-{expected_version}-" not in name:
        return -1
    if "cp310-abi3" not in name and py_tag not in name:
        return -1

    score_value = 0
    if system == "Darwin":
        if "macosx" not in name:
            return -1
        if "universal2" in name:
            score_value += 30
        elif arch not in name:
            return -1
    elif system == "Linux":
        if "manylinux" not in name and "linux" not in name:
            return -1
        if arch not in name:
            return -1
        if "manylinux" in name:
            score_value += 20
    else:
        return -1

    if "cp310-abi3" in name:
        score_value += 10
    return score_value

matches = sorted(
    ((score(asset), asset.get("browser_download_url", "")) for asset in assets),
    reverse=True,
)
for score_value, url in matches:
    if score_value >= 0 and url:
        print(url)
        sys.exit(0)
sys.exit(1)
PY
  )" || true
  rm -f "$metadata_file"

  [ -n "$wheel_url" ] || return 1
  printf '%s' "$wheel_url"
}

helix_native_git_requirement() {
  local repo_url="https://github.com/${DEFAULT_RELEASE_REPOSITORY}.git"
  if [ -n "${ENGRAM_RELEASE_REF:-}" ]; then
    repo_url="${repo_url}@${ENGRAM_RELEASE_REF}"
  fi
  printf 'helix-native @ git+%s#subdirectory=%s' "$repo_url" "$HELIX_NATIVE_SUBDIR"
}

local_helix_native_requirement() {
  local repo_root candidate
  repo_root="$(cd "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd || true)"
  [ -n "$repo_root" ] || return 1

  candidate="$repo_root/$HELIX_NATIVE_SUBDIR"
  if [ -f "$candidate/pyproject.toml" ] && [ -d "$candidate/../helix-db" ]; then
    printf 'helix-native @ file://%s' "$candidate"
    return
  fi

  return 1
}

resolve_helix_native_requirement() {
  if [ -n "${ENGRAM_HELIX_NATIVE_SOURCE:-}" ]; then
    printf '%s' "$ENGRAM_HELIX_NATIVE_SOURCE"
    return
  fi

  local wheel_url
  if wheel_url="$(discover_helix_native_release_wheel)"; then
    printf '%s' "$wheel_url"
    return
  fi

  if local_helix_native_requirement; then
    return
  fi

  helix_native_git_requirement
}

install_engram_tool_with_native() {
  local package_spec="$1"
  local helix_native_req
  helix_native_req="$(resolve_helix_native_requirement)"
  if [[ "$helix_native_req" == helix-native\ @\ file://* ]]; then
    note "Using local Helix native source; build can take several minutes and requires Rust/Cargo."
  elif [[ "$helix_native_req" == helix-native\ @\ git+* ]]; then
    note "No compatible Helix native release wheel was found; building from Engram's bundled source."
    note "This can take several minutes and requires Rust/Cargo."
  fi
  if [[ "$helix_native_req" == helix-native\ @\ file://* || "$helix_native_req" == helix-native\ @\ git+* ]]; then
    if ! command -v cargo >/dev/null 2>&1 || ! cargo --version >/dev/null 2>&1; then
      warn "Helix native source build requires a working Rust toolchain."
      note "Install Rust with rustup and run: rustup default stable"
      return 1
    fi
  fi
  info "Using Helix native runtime: $helix_native_req"
  uv tool install --force --reinstall-package engram --with "$helix_native_req" "$package_spec"
}

usage() {
  cat <<'EOF'
Usage: engramctl <command> [options]

Commands:
  setup                          Interactive mode picker + config
  setup --mode helix|lite|auto   Preselect a local no-Docker backend
  quickstart [--project PATH]    Setup native mode, start, connect, bootstrap, doctor
             [--install-openclaw] [--connect CLIENT]
             [--axi-hooks] [--capture]
  doctor                         Run the installed-user readiness gate
  connect <client>               Configure MCP for codex|claude-code|cursor|windsurf|claude-desktop|openclaw
                                  Add --axi for read-only AXI startup context on codex|claude-code
  bootstrap [--include GLOB] <project-dir> [...]
                                  Index selected project docs, notes, exports
  install [--mode full] [--no-open]
  install-openclaw
  start
  stop
  status
  storage                        Show resolved storage paths and disk growth
  logs [service]
  update
  upgrade                        Upgrade from local mode to full
  uninstall [--purge-data]
EOF
}

ensure_supported_os() {
  case "$(uname -s)" in
    Darwin|Linux) ;;
    *) die "Engram one-click install currently supports macOS and Linux only." ;;
  esac
}

ensure_commands() {
  for cmd in curl tar; do
    command -v "$cmd" >/dev/null 2>&1 || die "Missing required command: $cmd"
  done
}

detect_docker_compose() {
  if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
    DOCKER_COMPOSE=(docker compose)
    return
  fi
  if command -v docker-compose >/dev/null 2>&1; then
    DOCKER_COMPOSE=(docker-compose)
    return
  fi
  die "Docker Compose is required. Install Docker Desktop (macOS) or Docker Engine + Compose plugin (Linux)."
}

ensure_docker_ready() {
  [ "${ENGRAM_INSTALL_SKIP_RUNTIME:-0}" = "1" ] && return
  command -v docker >/dev/null 2>&1 || die "Docker is required for full mode."
  detect_docker_compose
  docker info >/dev/null 2>&1 || die "Docker is installed but the daemon is not running."
}

ensure_directories() {
  mkdir -p "$INSTALL_ROOT/releases" "$INSTALL_ROOT/data/server" "$INSTALL_ROOT/data/redis" \
    "$INSTALL_ROOT/data/falkordb" "$BIN_DIR"
}

install_launcher() {
  mkdir -p "$BIN_DIR"
  ln -sfn "$INSTALL_ROOT/current/engramctl" "$BIN_DIR/engramctl"
  if [[ ":$PATH:" != *":$BIN_DIR:"* ]]; then
    note "Add $BIN_DIR to your PATH to run engramctl directly."
  fi
}

random_hex() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 24
  else
    od -An -N24 -tx1 /dev/urandom | tr -d ' \n'
  fi
}

# ─── Variant Detection ──────────────────────────────────────────────

detect_variant() {
  # Check lite env file first
  if [ -f "$LITE_ENV_FILE" ]; then
    local variant
    variant="$(grep -E '^ENGRAM_INSTALL_VARIANT=' "$LITE_ENV_FILE" 2>/dev/null | cut -d= -f2 || true)"
    if [ -n "$variant" ]; then
      echo "$variant"
      return
    fi
  fi
  # Check full env file
  if [ -f "$FULL_ENV_FILE" ]; then
    local variant
    variant="$(grep -E '^ENGRAM_INSTALL_VARIANT=' "$FULL_ENV_FILE" 2>/dev/null | cut -d= -f2 || true)"
    if [ -n "$variant" ]; then
      echo "$variant"
      return
    fi
  fi
  # No install found
  echo ""
}

env_file_for_variant() {
  local variant="$1"
  if [ "$variant" = "lite" ]; then
    echo "$LITE_ENV_FILE"
  else
    echo "$FULL_ENV_FILE"
  fi
}

load_existing_env() {
  local env_file="${1:-}"
  if [ -z "$env_file" ]; then
    local variant
    variant="$(detect_variant)"
    env_file="$(env_file_for_variant "${variant:-full}")"
  fi
  if [ -f "$env_file" ]; then
    set -a
    # shellcheck disable=SC1090
    source "$env_file"
    set +a
  fi
}

prompt_value() {
  local prompt="$1"
  local default="${2:-}"
  local value=""
  if [ -n "$default" ]; then
    read -r -p "$prompt [$default]: " value || true
    echo "${value:-$default}"
  else
    read -r -p "$prompt: " value || true
    echo "$value"
  fi
}

# ─── Env File Writers ────────────────────────────────────────────────

write_lite_env_file() {
  local engine_mode="${1:-lite}"
  mkdir -p "$ENGRAM_HOME"

  local anthropic="${ANTHROPIC_API_KEY:-${ENGRAM_ANTHROPIC_API_KEY:-}}"
  if [ -z "$anthropic" ] && [ "${ENGRAM_INSTALL_NONINTERACTIVE:-0}" != "1" ]; then
    anthropic="$(prompt_value 'Anthropic API key (optional, press enter to use deterministic extraction)')"
  fi

  local voyage="${VOYAGE_API_KEY:-${ENGRAM_VOYAGE_API_KEY:-}}"
  if [ -z "$voyage" ] && [ "${ENGRAM_INSTALL_NONINTERACTIVE:-0}" != "1" ]; then
    voyage="$(prompt_value 'Voyage AI key (optional, press enter to skip)')"
  fi

  local auth_token="${ENGRAM_AUTH__BEARER_TOKEN:-}"
  local enc_key="${ENGRAM_ENCRYPTION__MASTER_KEY:-}"

  cat >"$LITE_ENV_FILE" <<EOF
# Generated by engramctl setup. Edit values here to customize the install.
ENGRAM_INSTALL_VARIANT=lite

ENGRAM_API_PORT=${ENGRAM_API_PORT:-8100}

ANTHROPIC_API_KEY=$anthropic
VOYAGE_API_KEY=${voyage:-}

ENGRAM_MODE=$engine_mode
ENGRAM_ACTIVATION__CONSOLIDATION_PROFILE=${ENGRAM_ACTIVATION__CONSOLIDATION_PROFILE:-standard}
ENGRAM_ACTIVATION__RECALL_PROFILE=${ENGRAM_ACTIVATION__RECALL_PROFILE:-all}
ENGRAM_ACTIVATION__INTEGRATION_PROFILE=${ENGRAM_ACTIVATION__INTEGRATION_PROFILE:-rework}
ENGRAM_ACTIVATION__WORKER_ENABLED=${ENGRAM_ACTIVATION__WORKER_ENABLED:-true}

ENGRAM_AUTH__ENABLED=${ENGRAM_AUTH__ENABLED:-false}
ENGRAM_AUTH__BEARER_TOKEN=$auth_token
ENGRAM_ENCRYPTION__ENABLED=${ENGRAM_ENCRYPTION__ENABLED:-false}
ENGRAM_ENCRYPTION__MASTER_KEY=$enc_key
EOF

  if [ "$engine_mode" = "helix" ]; then
    cat >>"$LITE_ENV_FILE" <<EOF
ENGRAM_HELIX__TRANSPORT=native
ENGRAM_HELIX__DATA_DIR=${ENGRAM_HELIX__DATA_DIR:-}
EOF
  fi
}

