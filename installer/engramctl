openclaw_mcp_json() {
  local url="$1"
  python3 - "$url" <<'PY'
import json
import sys

print(json.dumps({"url": sys.argv[1], "transport": "streamable-http"}))
PY
}

openclaw_command_label() {
  if [ -n "${ENGRAM_OPENCLAW_COMMAND:-}" ]; then
    printf '%s' "$ENGRAM_OPENCLAW_COMMAND"
    return 0
  fi
  if command -v openclaw >/dev/null 2>&1; then
    printf 'openclaw'
    return 0
  fi
  if [ "${ENGRAM_OPENCLAW_DISABLE_NPX:-0}" != "1" ] && command -v npx >/dev/null 2>&1; then
    printf 'npx -y openclaw'
    return 0
  fi
  return 1
}

run_openclaw_command() {
  if [ -n "${ENGRAM_OPENCLAW_COMMAND:-}" ]; then
    # shellcheck disable=SC2086
    $ENGRAM_OPENCLAW_COMMAND "$@"
    return
  fi
  if command -v openclaw >/dev/null 2>&1; then
    openclaw "$@"
    return
  fi
  if [ "${ENGRAM_OPENCLAW_DISABLE_NPX:-0}" != "1" ] && command -v npx >/dev/null 2>&1; then
    npx -y openclaw "$@"
    return
  fi
  return 127
}

configure_openclaw_mcp() {
  local url="$1"
  local verify="${2:-0}"
  local payload
  payload="$(openclaw_mcp_json "$url")"
  local openclaw_cmd
  openclaw_cmd="$(openclaw_command_label || true)"

  if [ -z "$openclaw_cmd" ]; then
    warn "OpenClaw CLI not found and npx is unavailable; MCP config was not written."
    dim "Install OpenClaw or npm/npx, then run:"
    dim "  npx -y openclaw mcp set engram '$payload'"
    return 0
  fi

  if run_openclaw_command mcp set engram "$payload"; then
    info "Configured OpenClaw MCP server 'engram' with $openclaw_cmd"
  else
    warn "OpenClaw MCP config failed."
    dim "Manual command:"
    dim "  $openclaw_cmd mcp set engram '$payload'"
    return 0
  fi

  if [ "$verify" = "1" ]; then
    run_openclaw_command mcp show engram --json || warn "OpenClaw MCP config was written, but verification failed."
  else
    dim "Verify: $openclaw_cmd mcp show engram --json"
  fi
}

install_axi_hook_for_client() {
  local client="$1"
  local capture="${2:-0}"

  case "$client" in
    codex) ;;
    claude-code|claude) client="claude-code" ;;
    *)
      warn "AXI hooks are currently supported for Codex and Claude Code only."
      dim "For shell-capable clients, run: engram axi --project \"\$PWD\" --budget 800 --timeout 3"
      return 0
      ;;
  esac

  local engram_cmd
  engram_cmd="$(find_engram_command)"
  local args=(
    axi hooks install "$client"
    --server-url "$(api_base_url)"
    --timeout 3
    --budget 800
    --engram-command "$engram_cmd"
  )
  if [ "$capture" = "1" ]; then
    args+=(--capture)
  fi
  "$engram_cmd" "${args[@]}"
}

install_openclaw_skill() {
  load_existing_env
  local source_dir="$INSTALL_ROOT/current/skills/engram-memory"
  local target_dir="$HOME/.openclaw/skills/$OPENCLAW_SKILL_SLUG"
  [ -d "$source_dir" ] || die "OpenClaw skill asset is missing from the current install bundle."
  mkdir -p "$(dirname "$target_dir")"
  rm -rf "$target_dir"
  cp -R "$source_dir" "$target_dir"
  verify_api_reachable
  info "Installed OpenClaw skill at $target_dir"
}

stage_current_bundle() {
  local release_version="${ENGRAM_RELEASE_VERSION:-dev}"
  local release_dir="$INSTALL_ROOT/releases/$release_version"
  local source_dir
  source_dir="$(cd "$BUNDLE_ROOT" >/dev/null 2>&1 && pwd)"
  local target_parent
  target_parent="$(cd "$INSTALL_ROOT/releases" >/dev/null 2>&1 && pwd)"
  local target_dir="$target_parent/$release_version"

  if [ "$source_dir" != "$target_dir" ]; then
    rm -rf "$target_dir"
    mkdir -p "$target_dir"
    cp -R "$source_dir"/. "$target_dir"/
  fi

  ln -sfn "$target_dir" "$INSTALL_ROOT/current"
}

download_bundle() {
  local temp_dir="$1"
  local bundle_url="${ENGRAM_BUNDLE_URL:-https://github.com/${DEFAULT_RELEASE_REPOSITORY}/releases/latest/download/engram-install-bundle.tar.gz}"
  local sha_url="${ENGRAM_BUNDLE_SHA256_URL:-https://github.com/${DEFAULT_RELEASE_REPOSITORY}/releases/latest/download/engram-install-bundle.sha256}"
  local bundle_path="$temp_dir/engram-install-bundle.tar.gz"
  local sha_path="$temp_dir/engram-install-bundle.sha256"

  curl -fsSL "$bundle_url" -o "$bundle_path"
  if curl -fsSL "$sha_url" -o "$sha_path"; then
    local expected actual
    expected="$(awk '{print $1}' "$sha_path")"
    if command -v sha256sum >/dev/null 2>&1; then
      actual="$(sha256sum "$bundle_path" | awk '{print $1}')"
    else
      actual="$(shasum -a 256 "$bundle_path" | awk '{print $1}')"
    fi
    [ "$expected" = "$actual" ] || die "Downloaded install bundle checksum mismatch."
  else
    warn "Checksum asset not found. Continuing without bundle verification."
  fi

  mkdir -p "$temp_dir/extracted"
  tar -xzf "$bundle_path" -C "$temp_dir/extracted"
  echo "$temp_dir/extracted"
}

# ─── Local Mode Helpers ──────────────────────────────────────────────

find_engram_command() {
  local cmd
  cmd="$(find_engram_command_optional)"
  if [ -n "$cmd" ]; then
    echo "$cmd"
    return
  fi
  die "engram command not found. Re-run install or check your PATH."
}

find_engram_command_optional() {
  # Find the engram CLI command (uv tool or pip installed)
  if command -v engram >/dev/null 2>&1; then
    command -v engram
    return
  fi
  # Check uv tool bin
  if [ -x "$HOME/.local/bin/engram" ]; then
    echo "$HOME/.local/bin/engram"
    return
  fi
}

launch_agent_domain() {
  printf 'gui/%s' "$(id -u)"
}

launch_agent_service() {
  printf '%s/%s' "$(launch_agent_domain)" "$LITE_LAUNCH_AGENT_LABEL"
}

launch_agent_available() {
  [ "$(uname -s)" = "Darwin" ] || return 1
  command -v launchctl >/dev/null 2>&1 || return 1
  [ -f "$LITE_LAUNCH_AGENT_PLIST" ] || return 1
}

launch_agent_print() {
  launch_agent_available || return 1
  launchctl print "$(launch_agent_service)" 2>/dev/null
}

launch_agent_is_running() {
  launch_agent_print | grep -q 'state = running'
}

launch_agent_pid() {
  launch_agent_print | awk -F'= ' '/^[[:space:]]*pid = / {print $2; exit}'
}

launch_agent_start() {
  launch_agent_available || return 1
  if launch_agent_is_running; then
    return 0
  fi

  local domain service
  domain="$(launch_agent_domain)"
  service="$(launch_agent_service)"
  if ! launchctl print "$service" >/dev/null 2>&1; then
    launchctl bootstrap "$domain" "$LITE_LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  fi
  launchctl kickstart -k "$service" >/dev/null 2>&1 || true
  local attempts=10
  while [ "$attempts" -gt 0 ]; do
    if launch_agent_is_running; then
      return 0
    fi
    attempts=$((attempts - 1))
    sleep 1
  done
  return 1
}

launch_agent_stop() {
  launch_agent_available || return 1
  if ! launchctl print "$(launch_agent_service)" >/dev/null 2>&1; then
    return 0
  fi
  launchctl bootout "$(launch_agent_service)" >/dev/null 2>&1 \
    || launchctl bootout "$(launch_agent_domain)" "$LITE_LAUNCH_AGENT_PLIST" >/dev/null 2>&1
}

lite_pid_is_running() {
  if [ -f "$LITE_PID_FILE" ]; then
    local pid
    pid="$(cat "$LITE_PID_FILE")"
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    # Stale PID file
    rm -f "$LITE_PID_FILE"
  fi
  return 1
}

lite_is_running() {
  lite_pid_is_running || launch_agent_is_running
}

local_startup_attempts() {
  if [ -n "${ENGRAM_STARTUP_TIMEOUT_SECONDS:-}" ]; then
    printf '%s' "$ENGRAM_STARTUP_TIMEOUT_SECONDS"
    return
  fi
  if [ "${ENGRAM_MODE:-lite}" = "helix" ]; then
    printf '90'
  else
    printf '30'
  fi
}

wait_for_local_health() {
  local port="$1"
  local attempts
  attempts="$(local_startup_attempts)"
  while [ "$attempts" -gt 0 ]; do
    if curl --connect-timeout 1 --max-time 5 -fsS "http://127.0.0.1:${port}/health" >/dev/null 2>&1; then
      return 0
    fi
    attempts=$((attempts - 1))
    sleep 1
  done
  return 1
}

wait_for_local_offline() {
  local port="$1"
  local attempts="${2:-15}"
  while [ "$attempts" -gt 0 ]; do
    if ! curl --connect-timeout 1 --max-time 2 -fsS "http://127.0.0.1:${port}/health" >/dev/null 2>&1; then
      return 0
    fi
    attempts=$((attempts - 1))
    sleep 1
  done
  return 1
}

lite_start() {
  if lite_pid_is_running; then
    local pid
    pid="$(cat "$LITE_PID_FILE")"
    info "Engram is already running (PID $pid)."
    return 0
  fi

  load_existing_env "$LITE_ENV_FILE"
  mkdir -p "$LITE_LOG_DIR"

  local engram_cmd
  engram_cmd="$(find_engram_command)"
  local port="${ENGRAM_API_PORT:-8100}"

  if launch_agent_available; then
    if launch_agent_start; then
      local agent_pid
      agent_pid="$(launch_agent_pid || true)"
      if wait_for_local_health "$port"; then
        info "Engram started with LaunchAgent ${LITE_LAUNCH_AGENT_LABEL}${agent_pid:+ (PID $agent_pid)}."
        dim "API: http://127.0.0.1:${port}"
        dim "Logs: $LITE_LOG_FILE"
        dim "LaunchAgent: $LITE_LAUNCH_AGENT_PLIST"
        return 0
      fi
      warn "LaunchAgent ${LITE_LAUNCH_AGENT_LABEL} is loaded but health is not responding yet."
      dim "Check logs: tail -f $LITE_LOG_FILE"
      return 1
    fi
    warn "LaunchAgent ${LITE_LAUNCH_AGENT_LABEL} exists but could not be started."
    dim "LaunchAgent: $LITE_LAUNCH_AGENT_PLIST"
    return 1
  fi

  # Start engram serve in background, bound to loopback only
  nohup env $(grep -v '^#' "$LITE_ENV_FILE" | grep '=' | xargs) \
    "$engram_cmd" serve --host 127.0.0.1 --port "$port" \
    >> "$LITE_LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" > "$LITE_PID_FILE"

  if wait_for_local_health "$port"; then
    local engine_mode="${ENGRAM_MODE:-lite}"
    info "Engram started (PID $pid, $engine_mode mode)."
    dim "API: http://127.0.0.1:${port}"
    dim "Logs: $LITE_LOG_FILE"
    if [ "$engine_mode" = "helix" ]; then
      dim "Native data: ${ENGRAM_HELIX__DATA_DIR:-helix_native default}"
    elif [ "$engine_mode" = "auto" ]; then
      dim "Data: auto-detected by Engram"
    else
      dim "DB: $LITE_DB_FILE"
    fi
    return 0
  fi

  warn "Engram process started (PID $pid) but health check not responding yet."
  dim "Check logs: tail -f $LITE_LOG_FILE"
  return 1
}

lite_stop() {
  load_existing_env "$LITE_ENV_FILE"
  local port="${ENGRAM_API_PORT:-8100}"
  local stopped=0
  if lite_pid_is_running; then
    local pid
    pid="$(cat "$LITE_PID_FILE")"
    kill "$pid" 2>/dev/null || true

    # Wait for process to exit
    local attempts=10
    while [ "$attempts" -gt 0 ] && kill -0 "$pid" 2>/dev/null; do
      attempts=$((attempts - 1))
      sleep 1
    done

    if kill -0 "$pid" 2>/dev/null; then
      kill -9 "$pid" 2>/dev/null || true
    fi

    rm -f "$LITE_PID_FILE"
    stopped=1
  elif [ -f "$LITE_PID_FILE" ]; then
    rm -f "$LITE_PID_FILE"
  fi

  if launch_agent_is_running; then
    if launch_agent_stop; then
      stopped=1
    else
      warn "Could not stop LaunchAgent ${LITE_LAUNCH_AGENT_LABEL}."
      dim "Run: launchctl bootout $(launch_agent_service)"
      return 1
    fi
  fi

  if [ "$stopped" != "1" ]; then
    info "Engram is not running."
    return 0
  fi
  if ! wait_for_local_offline "$port"; then
    warn "Engram stop was requested, but API still responds on port $port."
    dim "Check listener: lsof -nP -iTCP:${port} -sTCP:LISTEN"
    return 1
  fi
  info "Engram stopped."
}

lite_status() {
  load_existing_env "$LITE_ENV_FILE"
  local port="${ENGRAM_API_PORT:-8100}"
  local engine_mode="${ENGRAM_MODE:-lite}"
  local sqlite_path="${ENGRAM_SQLITE__PATH:-$LITE_DB_FILE}"
  local helix_data_dir="${ENGRAM_HELIX__DATA_DIR:-$HOME/.helix/engram-native}"
  local health_file
  local api_ok=0
  health_file="$(mktemp)"
  if curl --connect-timeout 1 --max-time 5 -fsS "http://127.0.0.1:${port}/health" -o "$health_file" 2>/dev/null; then
    api_ok=1
  fi

  echo -e "  ${BOLD}Engram Status (local mode)${RESET}"
  echo ""

  if lite_pid_is_running; then
    local pid
    pid="$(cat "$LITE_PID_FILE")"
    info "Server: running (PID $pid)"
  elif launch_agent_is_running; then
    local agent_pid
    agent_pid="$(launch_agent_pid || true)"
    info "Server: running (LaunchAgent ${LITE_LAUNCH_AGENT_LABEL}${agent_pid:+ PID $agent_pid})"
  elif [ "$api_ok" = "1" ]; then
    info "Server: running (API on port $port)"
  else
    warn "Server: not running"
  fi

  if [ "$engine_mode" = "helix" ]; then
    dim "Mode:   helix native (PyO3)"
    dim "Data:   $helix_data_dir"
    storage_path_line "Size:   " "$helix_data_dir"
  elif [ "$engine_mode" = "auto" ]; then
    dim "Mode:   auto (local resolver)"
    dim "Helix:  $helix_data_dir"
    dim "DB:     $sqlite_path"
  else
    dim "Mode:   lite (SQLite/local)"
    dim "DB:     $sqlite_path"
    storage_path_line "Size:   " "$sqlite_path"
  fi
  dim "Port:   $port"
  dim "Logs:   $LITE_LOG_FILE"
  dim "Config: $LITE_ENV_FILE"
  if launch_agent_available; then
    dim "Agent:  $LITE_LAUNCH_AGENT_PLIST"
  fi
  echo ""

  if [ "$api_ok" = "1" ]; then
    cat "$health_file"
    echo ""
  else
    warn "API is not responding on port $port."
  fi
  rm -f "$health_file"
}

storage_size() {
  local path="$1"
  if [ ! -e "$path" ]; then
    printf 'missing'
    return
  fi
  du -sh "$path" 2>/dev/null | awk '{print $1}'
}

storage_path_line() {
  local label="$1"
  local path="$2"
  if [ -e "$path" ]; then
    dim "${label}$(storage_size "$path")"
  else
    dim "${label}missing"
  fi
}

format_storage_json() {
  local json_file="$1"
  python3 - "$json_file" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)

counts = payload.get("counts") or {}
growth = payload.get("growthSinceStartup") or {}
disk = payload.get("disk") or {}
paths = payload.get("paths") or []


def signed(value, suffix=""):
    try:
        value = int(value)
    except Exception:
        value = 0
    sign = "+" if value >= 0 else ""
    return f"{sign}{value}{suffix}"


def human_bytes(value):
    try:
        value = int(value)
    except Exception:
        value = 0
    units = ("B", "KB", "MB", "GB", "TB")
    size = float(abs(value))
    for unit in units:
        if size < 1024 or unit == units[-1]:
            if unit == "B":
                return f"{int(size)} B"
            return f"{size:.1f} {unit}"
        size /= 1024
    return f"{size:.1f} TB"


def signed_human_bytes(value):
    try:
        value = int(value)
    except Exception:
        value = 0
    sign = "+" if value >= 0 else "-"
    return f"{sign}{human_bytes(value)}"


print("  Engram Storage")
print("")
print(f"  Mode:    {payload.get('mode', 'unknown')} ({payload.get('backend', 'unknown')})")
print(f"  Group:   {payload.get('groupId', 'default')}")
print(
    "  Disk:    "
    f"{disk.get('humanSize', '0 B')} "
    f"({signed_human_bytes(growth.get('bytes', 0))} since startup)"
)
print(
    "  Counts:  "
    f"{counts.get('episodes', 0)} episodes ({signed(growth.get('episodes', 0))}), "
    f"{counts.get('entities', 0)} entities ({signed(growth.get('entities', 0))}), "
    f"{counts.get('relationships', 0)} relationships "
    f"({signed(growth.get('relationships', 0))}), "
    f"{counts.get('cues', 0)} cues ({signed(growth.get('cues', 0))})"
)
print("")
print("  Paths:")
for item in paths:
    status = item.get("humanSize", "0 B") if item.get("exists") else "missing"
    print(f"  - {item.get('label', 'Storage')}: {status}")
    print(f"    {item.get('path', '')}")
PY
}

