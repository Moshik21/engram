{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://engram-api.fly.dev/api/:path*" },
    { "source": "/ws/:path*", "destination": "https://engram-api.fly.dev/ws/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
