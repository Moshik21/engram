# .env.example -- Copy to .env and fill in values
#
# Quick start:
#   Lite mode:  cp .env.example .env && edit ANTHROPIC_API_KEY
#   Full mode:  cp .env.example .env && edit keys && docker compose up -d
#   MCP + Dashboard: same as full mode, then add MCP config (see README)
#
# Dev setup:
#   cd server && uv sync --dev    # installs all deps including full-mode extras
#   uv run pytest -m "not requires_docker" -v   # run tests
#   uv run python -m engram.mcp.server           # start MCP server (stdio)

# Required -- Claude API key for entity extraction
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Mode: "lite" (SQLite), "full" (FalkorDB+Redis), or "auto" (detect)
# Use "auto" to gracefully fall back to lite when Docker services aren't running.
# ENGRAM_MODE=auto

# Lite mode settings
# ENGRAM_SQLITE__PATH=~/.engram/engram.db

# Server settings
# ENGRAM_SERVER__HOST=0.0.0.0
# ENGRAM_SERVER__PORT=8100

# Auth -- disabled by default for local dev
# ENGRAM_AUTH__ENABLED=false
# ENGRAM_AUTH__BEARER_TOKEN=      # generate: openssl rand -hex 32

# Encryption -- disabled by default
# ENGRAM_ENCRYPTION__ENABLED=false
# ENGRAM_ENCRYPTION__MASTER_KEY=  # generate: openssl rand -hex 32

# Embeddings (optional -- enables vector search via Voyage AI)
# VOYAGE_API_KEY=pa-your-key-here

# Full mode settings (only used when mode=full or MCP+Dashboard combo)
# Docker Compose defaults the password to "engram_dev" for local dev.
# If running MCP locally alongside Docker, uncomment these lines so the
# MCP server can connect to Docker's Redis/FalkorDB on mapped ports:
ENGRAM_FALKORDB__PASSWORD=engram_dev
ENGRAM_REDIS__URL=redis://:engram_dev@localhost:6381/0

# Override ports if defaults conflict with other services
# ENGRAM_FALKORDB_PORT=6380
# ENGRAM_REDIS_PORT=6381

# Override passwords (applies to both Docker and local connections)
# ENGRAM_FALKORDB_PASSWORD=engram_dev
# ENGRAM_REDIS_PASSWORD=engram_dev

# Activation engine tuning
# ENGRAM_ACTIVATION__DECAY_EXPONENT=0.5
# ENGRAM_ACTIVATION__SPREAD_MAX_HOPS=2
# ENGRAM_ACTIVATION__SPREAD_ENERGY_BUDGET=5.0

# Coherent full rework loop (recommended for MCP and Docker)
# This preset normalizes to consolidation_profile=standard + recall_profile=all,
# enables the cue/projection rollout bundle, the live natural recall stack,
# and epistemic routing across memory, artifacts, and runtime state.
ENGRAM_ACTIVATION__INTEGRATION_PROFILE=rework

# Partial rollouts can still be configured manually:
# ENGRAM_ACTIVATION__CONSOLIDATION_PROFILE=standard
# ENGRAM_ACTIVATION__RECALL_PROFILE=all
# Note: those two flags alone do not enable cue generation, cue recall, or
# projection-promotion. Use INTEGRATION_PROFILE=rework for the coherent loop.

# Natural recall overrides (normally enabled by recall_profile or integration_profile)
# ENGRAM_ACTIVATION__RECALL_NEED_ANALYZER_ENABLED=true
# ENGRAM_ACTIVATION__RECALL_NEED_STRUCTURAL_ENABLED=true
# ENGRAM_ACTIVATION__RECALL_NEED_GRAPH_PROBE_ENABLED=true
# ENGRAM_ACTIVATION__RECALL_NEED_SHIFT_ENABLED=true
# ENGRAM_ACTIVATION__RECALL_NEED_IMPOVERISHMENT_ENABLED=true
# ENGRAM_ACTIVATION__RECALL_NEED_SHIFT_SHADOW_ONLY=false
# ENGRAM_ACTIVATION__RECALL_NEED_IMPOVERISHMENT_SHADOW_ONLY=false

# Optional experimental controls (implemented but off by default)
# ENGRAM_ACTIVATION__RECALL_NEED_ADAPTIVE_THRESHOLDS_ENABLED=false
# ENGRAM_ACTIVATION__RECALL_NEED_GRAPH_OVERRIDE_ENABLED=false
# ENGRAM_ACTIVATION__RECALL_NEED_POST_RESPONSE_SAFETY_NET_ENABLED=false

# Epistemic routing / artifact substrate (normally enabled by integration_profile=rework)
# ENGRAM_ACTIVATION__EPISTEMIC_ROUTING_ENABLED=true
# ENGRAM_ACTIVATION__ARTIFACT_BOOTSTRAP_ENABLED=true
# ENGRAM_ACTIVATION__ARTIFACT_RECALL_ENABLED=true
# ENGRAM_ACTIVATION__EPISTEMIC_RUNTIME_EXECUTOR_ENABLED=true
# ENGRAM_ACTIVATION__DECISION_GRAPH_ENABLED=true
# ENGRAM_ACTIVATION__EPISTEMIC_RECONCILE_ENABLED=true
# ENGRAM_ACTIVATION__ANSWER_CONTRACT_ENABLED=true
# ENGRAM_ACTIVATION__CLAIM_STATE_MODELING_ENABLED=true
# ENGRAM_ACTIVATION__ARTIFACT_BOOTSTRAP_STALE_SECONDS=86400

# Default tenant group
# ENGRAM_DEFAULT_GROUP_ID=default
