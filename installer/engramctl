# ─── Commands ────────────────────────────────────────────────────────

command_setup() {
  local mode=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --mode)
        mode="${2:-}"
        shift 2
        ;;
      *)
        die "Unknown setup option: $1"
        ;;
    esac
  done

  echo ""
  echo -e "  ${BOLD}Engram Setup${RESET}"
  echo -e "  ${DIM}Persistent memory layer for AI agents${RESET}"
  echo ""

  # Mode selection
  if [ -z "$mode" ]; then
    if [ "${ENGRAM_INSTALL_NONINTERACTIVE:-0}" = "1" ]; then
      mode="lite"
    else
      echo -e "  ${BOLD}Choose install mode:${RESET}"
      echo ""
      echo -e "  ${GREEN}[1]${RESET} Helix native  ${DIM}(recommended — no Docker needed)${RESET}"
      echo -e "      ${DIM}PyO3 HelixDB backend, graph + vector + BM25 in-process${RESET}"
      echo ""
      echo -e "  ${CYAN}[2]${RESET} Lite  ${DIM}(fallback — no Docker needed)${RESET}"
      echo -e "      ${DIM}SQLite backend, all features, zero infrastructure${RESET}"
      echo ""
      echo -e "  ${CYAN}[3]${RESET} Full  ${DIM}(Docker required)${RESET}"
      echo -e "      ${DIM}FalkorDB + Redis, dashboard, scale/perf${RESET}"
      echo ""
      local choice
      read -r -p "  Choose [1/2/3] (1): " choice || true
      choice="${choice:-1}"
      case "$choice" in
        1|helix) mode="helix" ;;
        2|lite) mode="lite" ;;
        3|full) mode="full" ;;
        *) die "Invalid choice: $choice" ;;
      esac
    fi
  fi

  info "Selected mode: $mode"

  case "$mode" in
    helix|lite|auto) _setup_lite "$mode" ;;
    full) _setup_full ;;
    *) die "Invalid setup mode: $mode" ;;
  esac

  # OpenClaw skill prompt
  if [ "${ENGRAM_INSTALL_NONINTERACTIVE:-0}" != "1" ] && [ "${ENGRAM_SETUP_SKIP_OPENCLAW_PROMPT:-0}" != "1" ]; then
    echo ""
    local install_skill
    read -r -p "  Install OpenClaw skill? [y/N]: " install_skill || true
    if [ "${install_skill:-n}" = "y" ] || [ "${install_skill:-n}" = "Y" ]; then
      _install_openclaw_skill_lite
    fi
  fi

  echo ""
  echo -e "  ${BOLD}${GREEN}Setup complete!${RESET}"
  echo ""
  dim "Start Engram:  engramctl start"
  dim "Check status:  engramctl status"
  dim "View logs:     engramctl logs"
  dim "Stop:          engramctl stop"
  echo ""
}

_setup_lite() {
  local engine_mode="${1:-lite}"
  write_lite_env_file "$engine_mode"

  local engram_cmd
  engram_cmd="$(find_engram_command_optional)"

  if [ "$engine_mode" = "helix" ]; then
    _verify_helix_native_runtime "$engram_cmd"
  fi

  # Re-stamp ENGRAM_INSTALL_VARIANT for older env files and direct setup runs.
  if [ -f "$LITE_ENV_FILE" ]; then
    if ! grep -q '^ENGRAM_INSTALL_VARIANT=' "$LITE_ENV_FILE" 2>/dev/null; then
      echo "ENGRAM_INSTALL_VARIANT=lite" >> "$LITE_ENV_FILE"
    fi
  fi

  info "$engine_mode mode configured."
  dim "Config: $LITE_ENV_FILE"
}

_verify_helix_native_runtime() {
  local engram_cmd="${1:-}"

  if [ "${ENGRAM_INSTALL_SKIP_NATIVE_VERIFY:-0}" = "1" ]; then
    warn "Skipping Helix native verification."
    return
  fi

  if [ -z "$engram_cmd" ]; then
    warn "Could not verify Helix native support because the engram command was not found."
    return
  fi

  if ! "$engram_cmd" doctor --mode helix --skip-server --no-smoke --no-lifecycle --format json >/dev/null 2>&1; then
    if [ "${ENGRAM_INSTALL_SKIP_NATIVE_REPAIR:-0}" != "1" ] && command -v uv >/dev/null 2>&1; then
      warn "Helix native verification failed; trying to install the native runtime."
      if install_engram_tool_with_native "engram[local,native]" >/dev/null 2>&1; then
        engram_cmd="$(find_engram_command_optional)"
        if [ -n "$engram_cmd" ] \
          && "$engram_cmd" doctor --mode helix --skip-server --no-smoke --no-lifecycle --format json >/dev/null 2>&1; then
          info "Verified Helix native PyO3 runtime."
          return
        fi
      fi
    fi

    warn "Helix native verification failed."
    note "Native mode requires the helix_native PyO3 extension in the Engram tool environment."
    note "Rerun the public installer, or run: engramctl update"
    note "If a release wheel is unavailable, install Rust/Cargo so Engram can build helix-native."
    die "Helix native setup did not produce a runnable native runtime."
  fi

  info "Verified Helix native PyO3 runtime."
}

_setup_full() {
  ensure_docker_ready
  ensure_directories

  # Download and stage the Docker bundle
  local temp_dir
  temp_dir="$(mktemp -d)"
  trap 'rm -rf "$temp_dir"' RETURN

  info "Downloading install bundle..."
  local extracted
  extracted="$(download_bundle "$temp_dir")"

  # Stage and install via the bundled engramctl
  ENGRAM_INSTALL_ROOT="$INSTALL_ROOT" \
  ENGRAM_INSTALL_BIN_DIR="$BIN_DIR" \
  ENGRAM_INSTALL_SKIP_OPEN="${ENGRAM_INSTALL_SKIP_OPEN:-0}" \
  ENGRAM_INSTALL_NONINTERACTIVE="${ENGRAM_INSTALL_NONINTERACTIVE:-0}" \
  ENGRAM_INSTALL_SKIP_RUNTIME="${ENGRAM_INSTALL_SKIP_RUNTIME:-0}" \
    bash "$extracted/engramctl" install --mode full

  info "Full mode configured."
}

_install_openclaw_skill_lite() {
  local skill_source=""

  # Allow override for testing
  if [ -n "${ENGRAM_SKILL_SOURCE:-}" ] && [ -d "${ENGRAM_SKILL_SOURCE}" ]; then
    skill_source="$ENGRAM_SKILL_SOURCE"
  fi

  # Try to find skill from uv tool install location
  local engram_cmd
  engram_cmd="$(find_engram_command_optional)"
  if [ -n "$engram_cmd" ]; then
    # Get the package location
    local pkg_dir
    pkg_dir="$(python3 -c "import engram; import os; print(os.path.dirname(engram.__file__))" 2>/dev/null || true)"
    if [ -n "$pkg_dir" ] && [ -d "$pkg_dir/../../skills/engram-memory" ]; then
      skill_source="$pkg_dir/../../skills/engram-memory"
    fi
  fi

  # Fallback: download skill from GitHub
  if [ -z "$skill_source" ] || [ ! -d "$skill_source" ]; then
    local temp_dir
    temp_dir="$(mktemp -d)"
    local asset_slug
    for asset_slug in "$OPENCLAW_SKILL_SLUG" "engram-memory"; do
      local skill_url="https://github.com/${DEFAULT_RELEASE_REPOSITORY}/releases/latest/download/${asset_slug}-skill.tar.gz"
      if curl -fsSL "$skill_url" -o "$temp_dir/skill.tar.gz" 2>/dev/null; then
        rm -rf "$temp_dir/extracted"
        mkdir -p "$temp_dir/extracted"
        tar -xzf "$temp_dir/skill.tar.gz" -C "$temp_dir/extracted"
        if [ -d "$temp_dir/extracted/$OPENCLAW_SKILL_SLUG" ]; then
          skill_source="$temp_dir/extracted/$OPENCLAW_SKILL_SLUG"
        elif [ -d "$temp_dir/extracted/engram-memory" ]; then
          skill_source="$temp_dir/extracted/engram-memory"
        fi
        [ -n "$skill_source" ] && break
      fi
    done
  fi

  if [ -z "$skill_source" ] || [ ! -d "$skill_source" ]; then
    warn "Could not locate OpenClaw skill assets. Install manually later."
    return
  fi

  local target_dir="$HOME/.openclaw/skills/$OPENCLAW_SKILL_SLUG"
  mkdir -p "$(dirname "$target_dir")"
  rm -rf "$target_dir"
  cp -R "$skill_source" "$target_dir"
  info "Installed OpenClaw skill at $target_dir"
}

command_doctor() {
  local variant
  variant="$(detect_variant)"

  if [ "$variant" = "lite" ]; then
    load_local_env
    local engram_cmd
    engram_cmd="$(find_engram_command)"
    "$engram_cmd" doctor --mode "${ENGRAM_MODE:-lite}" --server-url "$(api_base_url)" "$@"
    return
  fi

  if [ -f "$FULL_ENV_FILE" ]; then
    load_existing_env "$FULL_ENV_FILE"
    local engram_cmd
    engram_cmd="$(find_engram_command)"
    "$engram_cmd" doctor --mode "${ENGRAM_MODE:-full}" --server-url "$(api_base_url)" "$@"
    return
  fi

  die "No install found. Run engramctl quickstart first."
}

command_connect() {
  local client="${1:-}"
  [ -n "$client" ] || die "Usage: engramctl connect codex|claude-code|cursor|windsurf|claude-desktop|openclaw|manual [--project PATH] [--verify] [--axi] [--capture]"
  shift || true

  local project_path="$PWD"
  local verify=0
  local install_axi=0
  local axi_capture=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --project)
        project_path="${2:-}"
        shift 2
        ;;
      --verify)
        verify=1
        shift
        ;;
      --axi)
        install_axi=1
        shift
        ;;
      --capture)
        install_axi=1
        axi_capture=1
        shift
        ;;
      *)
        die "Unknown connect option: $1"
        ;;
    esac
  done

  [ -d "$project_path" ] || die "Project path does not exist or is not a directory: $project_path"

  load_local_env
  local url
  url="$(api_base_url)/mcp"

  case "$client" in
    codex)
      local target="$HOME/.codex/config.toml"
      write_codex_mcp_config "$target" "$url"
      info "Configured Codex MCP at $target"
      dim "Restart Codex or start a new session to pick up Engram."
      ;;
    claude-code|claude)
      local target="$project_path/.mcp.json"
      write_mcp_http_config "$target" "$url"
      info "Configured Claude Code project MCP at $target"
      if [ "$verify" = "1" ]; then
        if command -v claude >/dev/null 2>&1; then
          claude mcp list || warn "Claude Code verification failed. Open Claude Code and run /mcp."
        else
          warn "Claude Code CLI not found; verify inside Claude Code with /mcp."
        fi
      else
        dim "Verify: open Claude Code in $project_path and run /mcp"
      fi
      ;;
    cursor)
      local target="$project_path/.cursor/mcp.json"
      write_mcp_http_config "$target" "$url"
      info "Configured Cursor project MCP at $target"
      dim "Restart Cursor or refresh MCP tools to pick up Engram."
      ;;
    windsurf)
      local target="$HOME/.codeium/windsurf/mcp_config.json"
      write_mcp_http_config "$target" "$url"
      info "Configured Windsurf Cascade MCP at $target"
      dim "Refresh Windsurf Cascade MCP tools to pick up Engram."
      ;;
    claude-desktop|desktop)
      local target
      if [ "$(uname -s)" = "Darwin" ]; then
        target="$HOME/Library/Application Support/Claude/claude_desktop_config.json"
      else
        target="$HOME/.config/Claude/claude_desktop_config.json"
      fi
      write_mcp_http_config "$target" "$url"
      info "Configured Claude Desktop MCP at $target"
      dim "Restart Claude Desktop to pick up Engram."
      ;;
    openclaw|claw)
      configure_openclaw_mcp "$url" "$verify"
      ;;
    manual)
      print_mcp_http_json "$url"
      ;;
    *)
      die "Unknown MCP client: $client"
      ;;
  esac

  if [ "$install_axi" = "1" ]; then
    install_axi_hook_for_client "$client" "$axi_capture"
  fi
}

command_bootstrap() {
  [ $# -gt 0 ] || die "Usage: engramctl bootstrap [--include GLOB] <project-dir> [...]"
  local include_patterns=()
  local source_paths=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --include)
        [ -n "${2:-}" ] || die "Usage: engramctl bootstrap --include GLOB <project-dir>"
        include_patterns+=("$2")
        shift 2
        ;;
      --)
        shift
        while [ $# -gt 0 ]; do
          source_paths+=("$1")
          shift
        done
        ;;
      -*)
        die "Unknown bootstrap option: $1"
        ;;
      *)
        source_paths+=("$1")
        shift
        ;;
    esac
  done

  [ "${#source_paths[@]}" -gt 0 ] || die "Usage: engramctl bootstrap [--include GLOB] <project-dir> [...]"
  load_local_env
  verify_api_reachable

  local base
  base="$(api_base_url)"
  for source_path in "${source_paths[@]}"; do
    [ -d "$source_path" ] || die "Bootstrap source must be a project directory: $source_path"
    local absolute_path payload
    absolute_path="$(cd "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)/$(basename "$source_path")"
    if [ "${#include_patterns[@]}" -gt 0 ]; then
      payload="$(
        python3 - "$absolute_path" "${include_patterns[@]}" <<'PY'
import json
import sys

body = {"project_path": sys.argv[1]}
if len(sys.argv) > 2:
    body["include_patterns"] = sys.argv[2:]
print(json.dumps(body))
PY
      )"
    else
      payload="$(
        python3 - "$absolute_path" <<'PY'
import json
import sys

body = {"project_path": sys.argv[1]}
print(json.dumps(body))
PY
      )"
    fi
    info "Bootstrapping selected source: $absolute_path"
    curl -fsS -X POST "$base/api/knowledge/bootstrap" \
      -H "Content-Type: application/json" \
      --data "$payload" \
      --connect-timeout 2 --max-time 180
    echo ""
  done
}

command_quickstart() {
  local mode="helix"
  local project_path=""
  local connect_client=""
  local install_openclaw=0
  local install_axi_hooks=0
  local axi_capture=0
  local no_start=0
  local no_doctor=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --mode)
        mode="${2:-}"
        shift 2
        ;;
      --project)
        project_path="${2:-}"
        shift 2
        ;;
      --connect)
        connect_client="${2:-}"
        shift 2
        ;;
      --install-openclaw)
        install_openclaw=1
        shift
        ;;
      --hooks|--axi-hooks)
        install_axi_hooks=1
        shift
        ;;
      --capture)
        install_axi_hooks=1
        axi_capture=1
        shift
        ;;
      --no-start)
        no_start=1
        shift
        ;;
      --no-doctor)
        no_doctor=1
        shift
        ;;
      *)
        die "Unknown quickstart option: $1"
        ;;
    esac
  done

  echo ""
  echo -e "  ${BOLD}Engram Quickstart${RESET}"
  echo -e "  ${DIM}Install -> Configure -> Start -> Connect MCP -> Bootstrap -> Doctor -> Use${RESET}"
  echo ""

  ensure_supported_os
  command -v python3 >/dev/null 2>&1 || die "Python 3.10+ is required."
  command -v uv >/dev/null 2>&1 || die "uv is required. Install uv, then rerun engramctl quickstart."

  if [ "$install_openclaw" = "1" ]; then
    ENGRAM_SETUP_SKIP_OPENCLAW_PROMPT=1 command_setup --mode "$mode"
  else
    command_setup --mode "$mode"
  fi

  if [ "$no_start" != "1" ]; then
    if ! command_start; then
      warn "Quickstart could not confirm Engram is ready."
      dim "Status: engramctl status"
      dim "Logs:   engramctl logs"
      return 1
    fi
  fi

  if [ "$install_openclaw" = "1" ]; then
    _install_openclaw_skill_lite
  fi

  if [ -z "$connect_client" ] && [ "${ENGRAM_INSTALL_NONINTERACTIVE:-0}" != "1" ]; then
    echo ""
    read -r -p "  Connect an MCP client now? [codex/claude-code/cursor/windsurf/claude-desktop/openclaw/skip] (skip): " connect_client || true
    connect_client="${connect_client:-skip}"
  fi
  if [ -n "$connect_client" ] && [ "$connect_client" != "skip" ]; then
    if [ -n "$project_path" ]; then
      command_connect "$connect_client" --project "$project_path"
    else
      command_connect "$connect_client"
    fi
  fi

  if [ "$install_axi_hooks" = "1" ]; then
    if [ -n "$connect_client" ] && [ "$connect_client" != "skip" ]; then
      install_axi_hook_for_client "$connect_client" "$axi_capture"
    else
      warn "AXI hook install was requested but no Codex or Claude Code client was selected."
      dim "Run later: engramctl connect codex --axi"
      dim "Or:        engramctl connect claude-code --axi"
    fi
  fi

  if [ -z "$project_path" ] && [ "${ENGRAM_INSTALL_NONINTERACTIVE:-0}" != "1" ]; then
    echo ""
    read -r -p "  Bootstrap a project directory now? [path or Enter to skip]: " project_path || true
  fi
  if [ -n "$project_path" ] && [ "$no_start" != "1" ]; then
    command_bootstrap "$project_path"
  elif [ -n "$project_path" ]; then
    note "Skipped bootstrap because --no-start was set. Run: engramctl bootstrap \"$project_path\""
  fi

  if [ "$no_doctor" != "1" ]; then
    command_doctor
  fi

  echo ""
  echo -e "  ${BOLD}${GREEN}Quickstart complete.${RESET}"
  local openclaw_cmd
  openclaw_cmd="$(openclaw_command_label || true)"
  openclaw_cmd="${openclaw_cmd:-openclaw}"
  dim "Use:      open your MCP client and ask it to call claim_authority before answering"
  dim "OpenClaw: $openclaw_cmd skills list --eligible && $openclaw_cmd mcp show engram --json"
  dim "Status:   engramctl status"
  dim "Doctor:   engramctl doctor"
  dim "Bootstrap another project: engramctl bootstrap /path/to/project"
  echo ""
}

command_install() {
  local mode="full"
  local open_browser=1

  while [ $# -gt 0 ]; do
    case "$1" in
      --mode)
        mode="${2:-}"
        shift 2
        ;;
      --no-open)
        open_browser=0
        shift
        ;;
      *)
        die "Unknown install option: $1"
        ;;
    esac
  done

  case "$mode" in
    full) ;;
    openclaw)
      die "OpenClaw mode is native-first. Run: engramctl quickstart --mode helix --install-openclaw --connect openclaw"
      ;;
    *) die "Install mode must be full." ;;
  esac

  ensure_supported_os
  ensure_commands
  ensure_directories
  stage_current_bundle
  install_launcher
  write_full_env_file "$mode"

  if [ "${ENGRAM_INSTALL_SKIP_RUNTIME:-0}" = "1" ]; then
    info "Bundle installed into $INSTALL_ROOT"
    return 0
  fi

  ensure_docker_ready
  compose pull
  compose up -d
  wait_for_health
  if [ "$open_browser" = "1" ]; then
    open_dashboard
  fi

  info "Engram is running."
  dim "Dashboard: http://127.0.0.1:${ENGRAM_DASHBOARD_PORT:-3000}"
  dim "API:       http://127.0.0.1:${ENGRAM_API_PORT:-8100}"
}

command_start() {
  local variant
  variant="$(detect_variant)"

  if [ "$variant" = "lite" ]; then
    lite_start
    return
  fi

  # Full mode
  [ -f "$FULL_ENV_FILE" ] || die "No install found. Run engramctl quickstart first."
  [ -f "$COMPOSE_FILE" ] || die "Current release bundle is missing."
  load_existing_env "$FULL_ENV_FILE"
  ensure_docker_ready
  compose up -d
  wait_for_health
  info "Engram started."
}

command_stop() {
  local variant
  variant="$(detect_variant)"

  if [ "$variant" = "lite" ]; then
    lite_stop
    return
  fi

  # Full mode
  [ -f "$FULL_ENV_FILE" ] || die "No install found."
  ensure_docker_ready
  compose stop
  info "Engram stopped."
}

command_status() {
  local variant
  variant="$(detect_variant)"

  if [ -z "$variant" ]; then
    die "No install found. Run engramctl quickstart first."
  fi

  if [ "$variant" = "lite" ]; then
    lite_status
    return
  fi

  # Full mode
  [ -f "$FULL_ENV_FILE" ] || die "No install found."
  load_existing_env "$FULL_ENV_FILE"
  ensure_docker_ready
  compose ps
  echo ""
  if curl --connect-timeout 1 --max-time 5 -fsS "http://127.0.0.1:${ENGRAM_API_PORT:-8100}/health" 2>/dev/null; then
    echo ""
  else
    warn "Engram API is not responding."
  fi
}

command_storage() {
  local variant
  variant="$(detect_variant)"

  if [ -z "$variant" ]; then
    die "No install found. Run engramctl quickstart first."
  fi

  if [ "$variant" = "lite" ]; then
    load_existing_env "$LITE_ENV_FILE"
    local port="${ENGRAM_API_PORT:-8100}"
    local tmp_file
    tmp_file="$(mktemp)"
    if curl --connect-timeout 1 --max-time 15 -fsS "http://127.0.0.1:${port}/api/storage" -o "$tmp_file" 2>/dev/null; then
      format_storage_json "$tmp_file"
      rm -f "$tmp_file"
      return
    fi
    rm -f "$tmp_file"
    offline_storage_status
    return
  fi

  load_existing_env "$FULL_ENV_FILE"
  local port="${ENGRAM_API_PORT:-8100}"
  local tmp_file
  tmp_file="$(mktemp)"
  if curl --connect-timeout 1 --max-time 15 -fsS "http://127.0.0.1:${port}/api/storage" -o "$tmp_file" 2>/dev/null; then
    format_storage_json "$tmp_file"
    rm -f "$tmp_file"
    return
  fi
  rm -f "$tmp_file"
  warn "Engram API is not responding on port $port."
  dim "Full mode graph/vector storage is managed by Docker services."
  dim "Run: engramctl status"
}

command_logs() {
  local service="${1:-}"
  local variant
  variant="$(detect_variant)"

  if [ "$variant" = "lite" ]; then
    lite_logs
    return
  fi

  # Full mode
  [ -f "$FULL_ENV_FILE" ] || die "No install found."
  ensure_docker_ready
  if [ -n "$service" ]; then
    compose logs -f "$service"
  else
    compose logs -f
  fi
}

command_update() {
  local variant
  variant="$(detect_variant)"

  if [ "$variant" = "lite" ]; then
    load_existing_env "$LITE_ENV_FILE"
    local engine_mode="${ENGRAM_MODE:-lite}"
    local package_spec="engram[local]"
    local github_spec="git+https://github.com/${DEFAULT_RELEASE_REPOSITORY}.git#subdirectory=server[local]"
    if [ "$engine_mode" = "helix" ]; then
      package_spec="engram[local,native]"
      github_spec="git+https://github.com/${DEFAULT_RELEASE_REPOSITORY}.git#subdirectory=server[local,native]"
    fi

    info "Updating Engram ($engine_mode local mode)..."
    local was_running=0
    if lite_is_running; then
      was_running=1
      lite_stop
    fi

    # Upgrade via uv tool
    if command -v uv >/dev/null 2>&1; then
      if [ "$engine_mode" = "helix" ]; then
        install_engram_tool_with_native "$github_spec" 2>/dev/null \
          || install_engram_tool_with_native "$package_spec" 2>/dev/null \
          || warn "Update failed. Try rerunning the public installer."
      else
        uv tool install --force "$github_spec" 2>/dev/null \
          || uv tool upgrade "$package_spec" 2>/dev/null \
          || warn "Update failed. Try: uv tool install --force '$package_spec'"
      fi
    else
      warn "uv not found. Install uv or update manually."
    fi

    if [ "$engine_mode" = "helix" ]; then
      local engram_cmd
      engram_cmd="$(find_engram_command_optional)"
      _verify_helix_native_runtime "$engram_cmd"
    fi

    if [ "$was_running" = "1" ]; then
      lite_start
    fi
    info "Engram updated."
    return
  fi

  # Full mode (existing logic)
  local temp_dir
  temp_dir="$(mktemp -d)"
  trap 'rm -rf "$temp_dir"' RETURN
  load_existing_env "$FULL_ENV_FILE"
  local extracted
  extracted="$(download_bundle "$temp_dir")"
  ENGRAM_INSTALL_ROOT="$INSTALL_ROOT" \
  ENGRAM_INSTALL_BIN_DIR="$BIN_DIR" \
  ENGRAM_INSTALL_SKIP_OPEN="${ENGRAM_INSTALL_SKIP_OPEN:-1}" \
  ENGRAM_INSTALL_NONINTERACTIVE="${ENGRAM_INSTALL_NONINTERACTIVE:-0}" \
  ENGRAM_INSTALL_SKIP_RUNTIME="${ENGRAM_INSTALL_SKIP_RUNTIME:-0}" \
    bash "$extracted/engramctl" install --mode "${ENGRAM_INSTALL_VARIANT:-full}" --no-open
  info "Engram updated."
}

command_upgrade() {
  local variant
  variant="$(detect_variant)"

  if [ "$variant" != "lite" ]; then
    die "Upgrade is only available from local mode. You're already running full mode."
  fi

  echo ""
  echo -e "  ${BOLD}Upgrading Local → Full${RESET}"
  echo ""
  note "Full mode starts with a fresh FalkorDB/Redis store."
  note "Your SQLite data is kept at $LITE_DB_FILE for reference"
  note "but is NOT auto-imported into the full-mode graph."
  echo ""

  # Stop lite if running
  if lite_is_running; then
    info "Stopping lite server..."
    lite_stop
  fi

  # Run full mode setup
  _setup_full

  # Update variant in lite env file so detect_variant returns full
  if [ -f "$LITE_ENV_FILE" ]; then
    if grep -q '^ENGRAM_INSTALL_VARIANT=' "$LITE_ENV_FILE" 2>/dev/null; then
      sed -i.bak 's/^ENGRAM_INSTALL_VARIANT=.*/ENGRAM_INSTALL_VARIANT=full/' "$LITE_ENV_FILE" 2>/dev/null || true
      rm -f "$LITE_ENV_FILE.bak"
    else
      echo "ENGRAM_INSTALL_VARIANT=full" >> "$LITE_ENV_FILE"
    fi
  fi

  info "Upgrade complete. Engram is now running in full mode."
  dim "Dashboard: http://127.0.0.1:${ENGRAM_DASHBOARD_PORT:-3000}"
  dim "API:       http://127.0.0.1:${ENGRAM_API_PORT:-8100}"
  dim "SQLite data preserved at $LITE_DB_FILE (not auto-imported)"
}

command_uninstall() {
  local purge_data=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --purge-data)
        purge_data=1
        shift
        ;;
      *)
        die "Unknown uninstall option: $1"
        ;;
    esac
  done

  local variant
  variant="$(detect_variant)"

  if [ "$variant" = "lite" ]; then
    # Stop lite server if running
    if lite_is_running; then
      lite_stop
    fi

    rm -f "$BIN_DIR/engramctl"

    # Remove engram uv tool
    if command -v uv >/dev/null 2>&1; then
      uv tool uninstall engram 2>/dev/null || true
    fi

    if [ "$purge_data" = "1" ]; then
      rm -rf "$ENGRAM_HOME"
    else
      rm -f "$LITE_PID_FILE"
    fi

    info "Engram uninstall complete."
    if [ "$purge_data" != "1" ]; then
      note "Preserved data and config under $ENGRAM_HOME"
    fi
    return
  fi

  # Full mode (existing logic)
  if [ -f "$FULL_ENV_FILE" ] && [ "${ENGRAM_INSTALL_SKIP_RUNTIME:-0}" != "1" ]; then
    ensure_docker_ready
    compose down --remove-orphans
  fi

  rm -f "$BIN_DIR/engramctl"
  rm -rf "$INSTALL_ROOT/current" "$INSTALL_ROOT/releases"
  if [ "$purge_data" = "1" ]; then
    rm -rf "$INSTALL_ROOT/data" "$FULL_ENV_FILE"
  fi

  info "Engram uninstall complete."
  if [ "$purge_data" != "1" ]; then
    note "Preserved data and .env under $INSTALL_ROOT"
  fi
}

main() {
  local cmd="${1:-}"
  if [ -z "$cmd" ]; then
    usage
    exit 1
  fi
  shift || true

  case "$cmd" in
    setup) command_setup "$@" ;;
    quickstart) command_quickstart "$@" ;;
    doctor) command_doctor "$@" ;;
    connect) command_connect "$@" ;;
    bootstrap) command_bootstrap "$@" ;;
    install) command_install "$@" ;;
    install-openclaw)
      local variant
      variant="$(detect_variant)"
      if [ "$variant" = "lite" ]; then
        _install_openclaw_skill_lite
      else
        install_openclaw_skill
      fi
      ;;
    start) command_start ;;
    stop) command_stop ;;
    status) command_status ;;
    storage) command_storage ;;
    logs) command_logs "$@" ;;
    update) command_update ;;
    upgrade) command_upgrade ;;
    uninstall) command_uninstall "$@" ;;
    help|-h|--help) usage ;;
    *) die "Unknown command: $cmd" ;;
  esac
}

main "$@"
